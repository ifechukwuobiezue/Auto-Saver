FROM node:20-slim

RUN apt-get update && apt-get install -y \
    chromium \
    libglib2.0-0 \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    libx11-6 \
    libxext6 \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf $(which chromium || which chromium-browser) /usr/local/bin/chromium-fixed \
    && /usr/local/bin/chromium-fixed --version

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/local/bin/chromium-fixed
ENV NODE_ENV=production

WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev \
    && rm -rf /root/.cache/puppeteer \
    && mkdir -p /root/.cache/puppeteer \
    && chmod 000 /root/.cache/puppeteer

COPY . .

CMD find /app/.wwebjs_auth -name "Singleton*" -delete 2>/dev/null; node index.js
